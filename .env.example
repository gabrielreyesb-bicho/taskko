# Copia este archivo a .env en el server y llena los valores.
# NO se commitea .env (está en .gitignore). Genera los secretos EN el server.

# --- Postgres: inicializa el contenedor db ---
POSTGRES_USER=todos
POSTGRES_PASSWORD=cambia_esto
POSTGRES_DB=todos_production

# --- Conexión de Rails: config/database.yml lee estas variables ---
DB_HOST=db
DB_USERNAME=todos
DB_PASSWORD=cambia_esto          # debe coincidir con POSTGRES_PASSWORD
DB_NAME=todos_production

# --- Rails ---
RAILS_ENV=production
SECRET_KEY_BASE=genera_con_"bin/rails secret"
RAILS_SERVE_STATIC_FILES=true    # sin nginx/Thruster, la app sirve sus assets
RAILS_LOG_TO_STDOUT=true         # logs visibles con "docker compose logs"

# --- API para TARS (recomendado al exponer por Cloudflare Tunnel) ---
# Si se define, la API exige header: Authorization: Bearer <API_TOKEN>
API_TOKEN=genera_un_token

# Descomenta solo si detrás del Tunnel aparece un redirect-loop de HTTPS:
# RAILS_FORCE_SSL=false
