<%# Tarjeta de una tarea en la lista. %>
<article class="rounded-xl border border-line bg-bg-card px-5 py-4 hover:border-brand-accent/50 transition <%= 'opacity-60' if task.status_cerrada? || task.status_cancelada? %>">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0">
      <%= link_to task.name, task_path(task),
            class: "font-medium text-ink hover:text-brand-light transition #{'line-through' if task.status_cerrada? || task.status_cancelada?}" %>

      <% if task.notes.present? %>
        <p class="mt-1 text-sm text-ink-muted line-clamp-2"><%= task.notes %></p>
      <% end %>

      <div class="mt-3 flex flex-wrap items-center gap-2 text-xs">
        <span class="rounded-md bg-bg-secondary px-2 py-1 text-ink-muted border border-line"><%= task.category_name %></span>
        <span class="rounded-md px-2 py-1 font-medium <%= priority_badge_classes(task) %>"><%= priority_label(task) %></span>
        <span class="rounded-md px-2 py-1 font-medium <%= status_badge_classes(task) %>"><%= status_label(task) %></span>
        <span class="text-ink-muted">· <%= assigned_label(task) %></span>
      </div>
    </div>

    <div class="flex flex-col items-end gap-2 shrink-0 text-right">
      <% if task.reminder_at.present? %>
        <div class="text-xs <%= reminder_overdue?(task) ? 'text-danger-text font-medium' : 'text-ink-muted' %>">
          <span class="opacity-70">🔔</span> <%= datetime_or_dash(task.reminder_at) %>
          <% if reminder_overdue?(task) %><span class="ml-1">vencido</span><% end %>
        </div>
      <% end %>
      <% if task.desired_completion_date.present? %>
        <div class="text-xs text-ink-muted">Meta: <%= date_or_dash(task.desired_completion_date) %></div>
      <% end %>

      <div class="flex items-center gap-1 mt-1">
        <% if task.status_abierta? || task.status_en_proceso? %>
          <%= button_to "Cerrar", status_task_path(task, value: "cerrada"), method: :patch,
                class: "rounded-md border border-line px-2.5 py-1 text-xs text-ink-muted hover:text-brand-light hover:border-brand-accent/60 transition" %>
        <% end %>
        <%= link_to "Editar", edit_task_path(task),
              class: "rounded-md border border-line px-2.5 py-1 text-xs text-ink-muted hover:text-ink hover:border-brand-accent/60 transition" %>
        <%= button_to "Eliminar", task_path(task), method: :delete,
              form: { data: { turbo_confirm: "¿Eliminar esta tarea?" } },
              class: "rounded-md border border-line px-2.5 py-1 text-xs text-ink-muted hover:text-danger-text hover:border-danger/50 transition" %>
      </div>
    </div>
  </div>
</article>
