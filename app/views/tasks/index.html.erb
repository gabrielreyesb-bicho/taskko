<% content_for :title, "Tareas · todos" %>

<div class="flex items-end justify-between gap-4 mb-6">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight">Tareas</h1>
    <p class="text-sm text-ink-muted mt-1"><%= pluralize(@tasks.size, "tarea", plural: "tareas") %></p>
  </div>
</div>

<%# Filtros por estatus %>
<div class="flex flex-wrap gap-2 mb-6">
  <% filter_chip = ->(label, value) do %>
    <% active = @status_filter == value || (value.nil? && @status_filter.nil?) %>
    <% path_params = { status: value, category_id: @category_filter }.compact_blank %>
    <%= link_to label, tasks_path(path_params),
          class: "rounded-full px-3.5 py-1.5 text-sm border transition #{active ? 'border-brand-accent bg-brand-dark text-brand-light' : 'border-line text-ink-muted hover:border-brand-accent/60 hover:text-ink'}" %>
  <% end %>
  <%= filter_chip.call("Todas", nil) %>
  <%= filter_chip.call("Abiertas", "abierta") %>
  <%= filter_chip.call("En proceso", "en_proceso") %>
  <%= filter_chip.call("Cerradas", "cerrada") %>
  <%= filter_chip.call("Canceladas", "cancelada") %>
</div>

<%# Filtros por categoría %>
<div class="flex flex-wrap gap-2 mb-6">
  <% category_chip = ->(label, value) do %>
    <% active = @category_filter == value || (value.nil? && @category_filter.nil?) %>
    <% path_params = { status: @status_filter, category_id: value }.compact_blank %>
    <%= link_to label, tasks_path(path_params),
          class: "rounded-full px-3.5 py-1.5 text-sm border transition #{active ? 'border-brand-accent bg-brand-dark text-brand-light' : 'border-line text-ink-muted hover:border-brand-accent/60 hover:text-ink'}" %>
  <% end %>
  <%= category_chip.call("Todas las categorías", nil) %>
  <% @categories.each do |category| %>
    <%= category_chip.call(category.name, category.id.to_s) %>
  <% end %>
</div>

<% if @tasks.any? %>
  <div class="space-y-3">
    <%= render @tasks %>
  </div>
<% else %>
  <div class="rounded-xl border border-dashed border-line bg-bg-card/40 px-6 py-16 text-center">
    <p class="text-ink-muted">No hay tareas por aquí.</p>
    <%= link_to "Crear la primera", new_task_path, class: "inline-block mt-3 text-brand-light hover:text-brand-accent underline underline-offset-4" %>
  </div>
<% end %>
