<% content_for :title, "#{@task.name} · Taskko" %>

<div class="mb-6">
  <%= link_to "← Volver", tasks_path, class: "text-sm text-ink-muted hover:text-ink transition" %>
</div>

<article class="rounded-xl border border-line bg-bg-card p-6">
  <div class="flex items-start justify-between gap-4">
    <h1 class="text-2xl font-semibold tracking-tight <%= 'line-through opacity-70' if @task.status_cerrada? || @task.status_cancelada? %>">
      <%= @task.name %>
    </h1>
    <div class="flex gap-2 shrink-0">
      <span class="rounded-md px-2.5 py-1 text-xs font-medium <%= priority_badge_classes(@task) %>"><%= priority_label(@task) %></span>
      <span class="rounded-md px-2.5 py-1 text-xs font-medium <%= status_badge_classes(@task) %>"><%= status_label(@task) %></span>
    </div>
  </div>

  <% if @task.notes.present? %>
    <p class="mt-4 text-ink-muted whitespace-pre-line"><%= @task.notes %></p>
  <% end %>

  <dl class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4 text-sm">
    <div>
      <dt class="text-ink-muted">Categoría</dt>
      <dd class="mt-0.5"><%= @task.category_name %></dd>
    </div>
    <div>
      <dt class="text-ink-muted">Asignado a</dt>
      <dd class="mt-0.5"><%= assigned_label(@task) %></dd>
    </div>
    <%# Igual que en la lista: el rojo lo pinta la fecha que manda. %>
    <% alerta_vencida = @task.overdue? && @task.desired_completion_date.blank? %>
    <div>
      <dt class="text-ink-muted">Fecha de recordatorio</dt>
      <dd class="mt-0.5 <%= 'text-danger-text font-medium' if alerta_vencida %>">
        <%= datetime_or_dash(@task.reminder_at) %>
        <% if alerta_vencida %> · vencida<% end %>
      </dd>
    </div>
    <div>
      <dt class="text-ink-muted">Fecha deseada de terminación</dt>
      <dd class="mt-0.5 <%= 'text-danger-text font-medium' if @task.overdue? %>">
        <%= date_or_dash(@task.desired_completion_date) %>
        <% if @task.overdue? %> · vencida<% end %>
      </dd>
    </div>
    <div>
      <dt class="text-ink-muted">Notificado a TARS</dt>
      <dd class="mt-0.5"><%= datetime_or_dash(@task.notified_at) %></dd>
    </div>
    <div>
      <dt class="text-ink-muted">Creación</dt>
      <dd class="mt-0.5"><%= datetime_or_dash(@task.created_at) %></dd>
    </div>
    <div>
      <dt class="text-ink-muted">Cierre real</dt>
      <dd class="mt-0.5"><%= datetime_or_dash(@task.closed_at) %></dd>
    </div>
  </dl>

  <div class="mt-8 flex items-center gap-3 border-t border-line pt-5">
    <%= link_to "Editar", edit_task_path(@task),
          class: "rounded-lg bg-brand hover:bg-brand-hover px-4 py-2 text-sm font-medium text-white transition" %>
    <%= button_to "Eliminar", task_path(@task), method: :delete,
          form: { data: { turbo_confirm: "¿Eliminar esta tarea?" } },
          class: "rounded-lg border border-line px-4 py-2 text-sm text-ink-muted hover:text-danger-text hover:border-danger/50 transition" %>
  </div>
</article>
