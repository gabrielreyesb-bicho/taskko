<%
  input_classes = "w-full rounded-lg border border-line bg-bg-secondary px-3 py-2 text-ink placeholder:text-ink-muted/50 focus:border-brand-accent focus:outline-none focus:ring-1 focus:ring-brand-accent transition"
  label_classes = "block text-sm font-medium text-ink-muted mb-1.5"
%>

<%= form_with model: category, class: "space-y-5" do |f| %>
  <% if category.errors.any? %>
    <div class="rounded-lg border border-danger/40 bg-danger/15 px-4 py-3 text-sm text-danger-text">
      <p class="font-medium mb-1"><%= pluralize(category.errors.count, "error", plural: "errores") %> al guardar:</p>
      <ul class="list-disc list-inside space-y-0.5">
        <% category.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Nombre", class: label_classes %>
    <%= f.text_field :name, class: input_classes, placeholder: "Casa", autofocus: true %>
  </div>

  <div class="flex items-center gap-3 pt-2">
    <%= f.submit (category.persisted? ? "Guardar cambios" : "Crear categoría"),
          class: "rounded-lg bg-brand hover:bg-brand-hover px-4 py-2.5 text-sm font-medium text-white cursor-pointer transition" %>
    <%= link_to "Cancelar", categories_path,
          class: "text-sm text-ink-muted hover:text-ink transition" %>
  </div>
<% end %>
